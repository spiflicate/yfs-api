{
   "$schema": "https://biomejs.dev/schemas/2.4.6/schema.json",
   "vcs": {
      "enabled": true,
      "clientKind": "git",
      "useIgnoreFile": true
   },
   "files": {
      "includes": ["**", "!!**/dist"]
   },
   "formatter": {
      "enabled": true,
      "indentStyle": "space",
      "indentWidth": 3,
      "lineWidth": 76
   },
   "linter": {
      "enabled": true,
      "rules": {
         "recommended": true
      }
   },
   "javascript": {
      "formatter": {
         "quoteStyle": "single"
      }
   },
   "assist": {
      "enabled": true,
      "actions": {
         "source": {
            "organizeImports": "on"
         }
      }
   },
   "html": {
      "experimentalFullSupportEnabled": true,
      "formatter": {
         "indentScriptAndStyle": true
      }
   }
}
